# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit the real file.

# Firebase project config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Creator identity — maps each Firebase Auth email to a creator name.
# Used for title testing votes. Must match the emails you created in Firebase Console.
VITE_PAB_EMAIL=pab@example.com
VITE_OPHER_EMAIL=opher@example.com
